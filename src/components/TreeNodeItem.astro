---
import Self from "./TreeNodeItem.astro";
import { makeLocalizedLessonHref, normalizeLang } from "../i18n/routing";

export type TreeNode = {
  name: string;
  label: string;
  marker?: string;
  path: string;
  isFile: boolean;
  isEmpty?: boolean;
  children?: TreeNode[];
};

const { node, activePath } = Astro.props as {
  node: TreeNode;
  activePath: string;
  lang?: string;
};

const lang = normalizeLang(Astro.props.lang);

const isActive = node.isFile && node.path === activePath;
---

<li>
  {
    node.isFile ? (
      <a
        class={"node " + (isActive ? "active" : "")}
        href={makeLocalizedLessonHref(node.path, lang)}
      >
        {node.label}
        {node.marker && <span class="nodeMarker">[{node.marker}]</span>}
      </a>
    ) : (
      <div class="node navhead">{node.label}</div>
    )
  }

  {
    node.children && node.children.length > 0 ? (
      <ul>
        {node.children
          .filter((c) => !(c.isFile && c.isEmpty))
          .map((child) => (
            <Self node={child} activePath={activePath} lang={lang} />
          ))}
      </ul>
    ) : null
  }
</li>
